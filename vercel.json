{
    "version": 2,
    "routes": [
        {
            "src": "/assets/(.*)",
            "headers": {
                "cache-control": "public, max-age=31536000, immutable"
            },
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "/"
        }
    ],
    "builds": [
        {
            "src": "build/web/**",
            "use": "@vercel/static"
        }
    ]
}